# ==============================================================================
# GetExpert AI Content Factory - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit the .env file with real secrets to the repository!

# 1. AI API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# 2. Database Integration (Google Sheets)
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=ContentPackQueue

# 3. Google API Secrets Fallbacks (Copy full JSON contents as inline strings)
GOOGLE_CREDENTIALS_JSON=your_google_credentials_oauth_json_here
GOOGLE_TOKEN_JSON=your_google_token_oauth_json_here

# 4. Blogger Publishing Integration
BLOGGER_BLOG_ID=your_blogger_blog_id_here

# 5. Logging and Performance Settings
LOG_LEVEL=INFO
